# Control de visibilidad del catálogo de productos
# Valores: 'true' para mostrar el catálogo, 'false' para mostrar mensaje de mantenimiento
NEXT_PUBLIC_CATALOG_ENABLED=true

# Modo mantenimiento global
# Valores: 'true' para activar modo mantenimiento, 'false' para funcionamiento normal
NEXT_PUBLIC_MAINTENANCE_MODE=false

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

